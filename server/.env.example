# Translation Pipeline Server Configuration
# Copy this file to .env and fill in the values

# Server Configuration
PORT=3000
HOST=localhost
NODE_ENV=development

# Microsoft Entra ID (Azure AD) Authentication
# Register an app at: https://portal.azure.com > App registrations
# Redirect URI: https://ritstjorn.namsbokasafn.is/api/auth/callback (type: Web)
# API permissions: openid, profile, email, User.Read (Microsoft Graph, delegated)
MS_CLIENT_ID=your_client_id_here
MS_CLIENT_SECRET=your_client_secret_here
MS_TENANT_ID=your_tenant_id_here
MS_CALLBACK_URL=http://localhost:3000/api/auth/callback

# JWT Configuration
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRY=24h

# Admin Users (comma-separated Microsoft email addresses that get admin access)
ADMIN_USERS=

# Auto-create users on first login (set to false to require admin pre-registration)
# AUTO_CREATE_USERS=true

# GitHub Repository (for PR sync — still uses GitHub for code hosting)
GITHUB_REPO_OWNER=namsbokasafn
GITHUB_REPO_NAME=namsbokasafn-efni
GITHUB_BASE_BRANCH=main
# Optional: Bot token for automated PR creation (if not using user tokens)
# GITHUB_BOT_TOKEN=ghp_xxxxx

# Matecat Configuration (Optional)
# Get your API key from: https://www.matecat.com/api/docs
# MATECAT_API_KEY=your_api_key
# MATECAT_BASE_URL=https://www.matecat.com

# CORS Configuration (Optional)
# CORS_ORIGIN=http://localhost:3000

# Email Notifications (Optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=notifications@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=Námsbókasafn <notifications@namsbokasafn.is>
# SMTP_SECURE=false

# Base URL for links in emails
# BASE_URL=https://ritstjorn.namsbokasafn.is
