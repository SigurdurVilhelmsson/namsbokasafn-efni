  <md:title>Inngangur</md:title>
  <md:abstract><list id="list-00001">
<item>Fyrsta efni</item>
<item>Annað efni</item>
</list></md:abstract>
  <md:uuid>00000000-0000-0000-0000-000000000001</md:uuid>
</metadata>

<content>

<para id="para-01">Þetta er fyrsta málsgreinin.</para>
<para id="para-02">Þessi málsgrein hefur <term id="term-01">efnafræði</term> sem lykilhugtak.</para>
   </content>
</document>
