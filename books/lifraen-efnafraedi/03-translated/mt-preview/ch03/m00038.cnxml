    <entry valign="top" align="left">1,0</entry>
    </row>
    <row valign="top">
    <entry valign="top" align="left">H ↔ CH<sub>3</sub> skyggt</entry>
    <entry valign="top" align="left">Aðallega snúningsálag</entry>
    <entry valign="top" align="left">6,0</entry>
    <entry valign="top" align="left">1,4</entry>
    </row>
    <row valign="top">
    <entry valign="top" align="left">CH<sub>3</sub> ↔ CH<sub>3</sub> skyggt</entry>
