  "questions": [
    {
      "id": 337958,
      "is_answer_order_important": false,
      "stimulus_html": "",
      "stem_html": "The amount of energy required to spin-flip a nucleus depends both on the strength of the external magnetic field and on the nucleus. At a field strength of 4.7 T, rf energy of 200 MHz is required to bring a <sup>1</sup>H nucleus into resonance, but energy of only 187 MHz will bring a <sup>19</sup>F nucleus into resonance. Calculate the amount of energy required to spin-flip a <sup>19</sup>F nucleus. Is this amount greater or less than that required to spin-flip a <sup>1</sup>H nucleus?",
      "answers": [],
      "hints": [],
      "formats": [
        "free-response"
      ],
      "combo_choices": [],
      "collaborator_solutions": [
        {
          "images": [],
          "solution_type": "detailed",
          "content_html": "7.5 × 10<sup>−5</sup> kJ/mol for <sup>19</sup>F; 8.0 × 10<sup>−5</sup> kJ/mol for <sup>1</sup>H"
        }
      ],
      "community_solutions": []
    }
  ],
