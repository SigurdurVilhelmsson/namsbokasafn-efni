    {
      "id": 342810,
      "is_answer_order_important": false,
      "stimulus_html": "",
      "stem_html": "We saw in <b>Section 9.3</b> that addition of HBr to a terminal alkyne leads to the Markovnikov addition product, with the Br bonding to the more highly substituted carbon. How could you use <sup>13</sup>C NMR to identify the product of the addition of 1 equivalent of HBr to 1-hexyne?",
      "answers": [],
      "hints": [],
      "formats": [
        "free-response"
      ],
      "combo_choices": [],
      "collaborator_solutions": [
        {
          "images": [],
          "solution_type": "detailed",
          "content_html": "A DEPT-90 spectrum would show two absorptions for the non-Markovnikov product (RCH<span data-math=\"\\text{=}\"></span>CHBr) but no absorptions for the Markovnikov product (RBrC<span data-math=\"\\text{=}\"></span>CH<sub>2</sub>)."
        }
      ],
      "community_solutions": []
    }
  ],
