      "id": 351824,
      "is_answer_order_important": false,
      "stimulus_html": "",
      "stem_html": "Assign <i>R</i> or <i>S</i> stereochemistry to the two chirality centers in isocitrate, and tell whether OH and H add to the Si face or the Re face of the double bond.",
      "answers": [],
      "hints": [],
      "formats": [
        "free-response"
      ],
      "combo_choices": [],
      "collaborator_solutions": [
        {
          "images": [],
          "solution_type": "detailed",
          "content_html": "The −OH group adds to the Re face at C2, and −H adds to the Re face at C3, to yield (2<i>R</i>,3<i>S</i>)-isocitrate."
        }
      ],
