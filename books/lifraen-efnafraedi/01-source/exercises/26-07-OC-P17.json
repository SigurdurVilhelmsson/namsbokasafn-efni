  "questions": [
    {
      "id": 348961,
      "is_answer_order_important": false,
      "stimulus_html": "",
      "stem_html": "Write all five steps required for the synthesis of Leu-Ala from alanine and leucine.",
      "answers": [],
      "hints": [],
      "formats": [
        "free-response"
      ],
      "combo_choices": [],
      "collaborator_solutions": [
        {
          "images": [],
          "solution_type": "detailed",
          "content_html": "<p><b>(1)</b> Protect the amino group of leucine.</p>\n<p><b>(2)</b>  Protect the carboxylic acid group of alanine.</p>\n<p><b>(3)</b> Couple the protected amino acids with DCC.</p>\n<p><b>(4)</b> Remove the leucine protecting group.</p>\n<p><b>(5)</b> Remove the alanine protecting group.</p>"
        }
      ],
      "community_solutions": []
    }
