        "free-response"
      ],
      "combo_choices": []
    },
    {
      "id": 358151,
      "is_answer_order_important": false,
      "stimulus_html": "",
      "stem_html": "The second part of the reaction is addition of the enamine to ribose 5-phosphate followed by loss of TPP ylide to give sedoheptulose 7-phosphate. Show the mechanism.",
