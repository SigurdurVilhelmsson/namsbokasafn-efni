      "is_answer_order_important": false,
      "stimulus_html": "",
      "stem_html": "Reduction of <small style=\"font-variant: small-caps\">D</small>-glucose leads to an optically active alditol (<small style=\"font-variant: small-caps\">D</small>-glucitol), whereas reduction of <small style=\"font-variant: small-caps\">D</small>-galactose leads to an optically inactive alditol. Explain.",
      "answers": [],
      "hints": [],
