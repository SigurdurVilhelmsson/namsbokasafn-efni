        "free-response"
      ],
      "combo_choices": [],
      "collaborator_solutions": [
        {
          "images": [],
          "solution_type": "detailed",
          "content_html": "<small style=\"font-variant: small-caps\">D</small>-Galactitol has a plane of symmetry and is a meso compound, whereas <small style=\"font-variant: small-caps\">D</small>-glucitol is chiral."
