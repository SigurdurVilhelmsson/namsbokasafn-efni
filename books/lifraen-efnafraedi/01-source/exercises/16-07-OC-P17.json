      "is_answer_order_important": false,
      "stimulus_html": "",
      "stem_html": "Treatment of <i>p</i>-bromotoluene with NaOH at 300 °C yields a mixture of two products, but treatment of <i>m</i>-bromotoluene with NaOH yields a mixture of three products. Explain.",
      "answers": [],
      "hints": [],
      "formats": [
        "free-response"
      ],
      "combo_choices": [],
      "collaborator_solutions": [
        {
          "images": [],
          "solution_type": "detailed",
          "content_html": "Only one benzyne intermediate can form from <i>p</i>-bromotoluene; two different benzyne intermediates can form from <i>m</i>-bromotoluene."
        }
      ],
