      "is_answer_order_important": false,
      "stimulus_html": "",
      "stem_html": "How could you distinguish between the isomers cyclopentanecarboxylic acid and 4-hydroxycyclohexanone by <sup>1</sup>H and <sup>13</sup>C NMR spectroscopy? (See Problem 20-15.)",
      "answers": [],
      "hints": [],
      "formats": [
        "free-response"
      ],
      "combo_choices": [],
      "collaborator_solutions": [
        {
          "images": [],
          "solution_type": "detailed",
          "content_html": "4-Hydroxycyclohexanone: <span class=\"magenta-text\">H</span>–C–O absorption near 4 <i>δ</i> in the <sup>1</sup>H spectrum and <span class=\"magenta-text\">C</span>═O absorption near 210 <i>δ</i> in the <sup>13</sup>C spectrum. Cyclopentanecarboxylic acid: –CO<sub>2</sub><span class=\"magenta-text\">H</span> absorption near 12 <i>δ</i> in the <sup>1</sup>H spectrum and  –<span class=\"magenta-text\">C</span>O<sub>2</sub>H absorption near 170 <i>δ</i> in the <sup>13</sup>C spectrum."
        }
      ],
