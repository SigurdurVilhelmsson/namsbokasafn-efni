        "free-response"
      ],
      "combo_choices": [],
      "collaborator_solutions": [
        {
          "images": [],
          "solution_type": "detailed",
          "content_html": "The −CHO end of <small style=\"font-variant: small-caps\">L</small>-gulose corresponds to the −CH<sub>2</sub>OH end of <small style=\"font-variant: small-caps\">D</small>-glucose after reduction."
