      "is_answer_order_important": false,
      "stimulus_html": "",
      "stem_html": "Reduction of <small style=\"font-variant: small-caps\">L</small>-gulose with NaBH<sub>4</sub> leads to the same alditol (<small style=\"font-variant: small-caps\">D</small>-glucitol) as reduction of <small style=\"font-variant: small-caps\">D</small>-glucose. Explain.",
      "answers": [],
      "hints": [],
