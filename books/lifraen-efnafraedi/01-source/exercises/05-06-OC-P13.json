        "free-response"
      ],
      "combo_choices": [],
      "collaborator_solutions": [
        {
          "images": [],
          "solution_type": "detailed",
          "content_html": "Compound <b>(a)</b> is D-erythrose 4-phosphate, <b>(d)</b> is its enantiomer, and <b>(b)</b> and <b>(c)</b> are diastereomers."
        }
