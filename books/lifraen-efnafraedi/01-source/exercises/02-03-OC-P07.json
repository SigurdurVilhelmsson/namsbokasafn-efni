  "stimulus_html": "Calculate formal charges for the nonhydrogen atoms in the following molecules:",
  "questions": [
    {
      "id": 358910,
      "is_answer_order_important": false,
      "stimulus_html": "",
      "stem_html": "<img class=\"scaled-down\" src=\"https://exercises.openstax.org/rails/active_storage/blobs/proxy/eyJfcmFpbHMiOnsibWVzc2FnZSI6IkJBaHBBdm9ZIiwiZXhwIjpudWxsLCJwdXIiOiJibG9iX2lkIn19--e525170f31aad0d1949d6fea8057cded9a1b7fae/OChem_02_03_007a.jpg\" alt=\"Text reading diazomethane and a condensed structure of C H 2 double bonded to N double bonded to another N. There are two nonbonding pairs on the final N.\">",
      "answers": [],
      "hints": [],
      "formats": [
        "free-response"
      ],
      "combo_choices": [],
      "collaborator_solutions": [
        {
          "images": [],
          "solution_type": "detailed",
          "content_html": "For carbon: FC = 4 − 8/2 − 0 = 0 For the middle nitrogen: FC = 5 − 8/2 − 0 = +1 For the end nitrogen: FC = 5 − 4/2 − 4 = −1"
        }
      ],
      "community_solutions": []
    },
    {
      "id": 358911,
      "is_answer_order_important": false,
      "stimulus_html": "",
      "stem_html": "<img class=\"scaled-down\" src=\"https://exercises.openstax.org/rails/active_storage/blobs/proxy/eyJfcmFpbHMiOnsibWVzc2FnZSI6IkJBaHBBdnNZIiwiZXhwIjpudWxsLCJwdXIiOiJibG9iX2lkIn19--f7d07db477703f1911dcbb8414672695fda44939/OChem_02_03_007b.jpg\" alt=\"Text reading acetonitrile oxide and a condensed structure of C H 3 C N O, with a triple bond between C and N and three nonbonding pairs on O.\">",
      "answers": [],
