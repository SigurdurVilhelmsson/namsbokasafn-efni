      "collaborator_solutions": [
        {
          "images": [],
          "solution_type": "detailed",
          "content_html": "Epoxidation of <i>cis</i>-2-butene yields <i>cis</i>-2,3-epoxybutane, while epoxidation of <i>trans</i>-2-butene yields <i>trans</i>-2,3-epoxybutane."
