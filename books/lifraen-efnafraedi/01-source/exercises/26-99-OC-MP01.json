  "is_vocab": false,
  "stimulus_html": "The reaction of ninhydrin with an <i>α</i>-amino acid occurs in several steps.",
  "questions": [
    {
      "id": 360852,
      "is_answer_order_important": false,
      "stimulus_html": "",
      "stem_html": "The first step is formation of an imine by reaction of the amino acid with ninhydrin. Show its structure and the mechanism of its formation.",
