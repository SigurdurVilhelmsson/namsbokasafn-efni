    {
      "id": 360414,
      "is_answer_order_important": false,
      "stimulus_html": "",
      "stem_html": "Draw the products you would expect from conrotatory and disrotatory cyclizations of (2<i>Z</i>,4<i>Z</i>,6<i>Z</i>)-2,4,6-octatriene. Which of the two paths would you expect the thermal reaction to follow?",
      "answers": [],
      "hints": [],
      "formats": [
        "free-response"
      ],
      "combo_choices": [],
      "collaborator_solutions": [
        {
          "images": [],
          "solution_type": "detailed",
          "content_html": "Disrotatory: <i>cis</i>-5,6-dimethyl-1,3-cyclohexadiene; <br>conrotatory: <i>trans</i>-5,6-dimethyl-1,3-cyclohexadiene. Disrotatory closure occurs."
        }
      ],
