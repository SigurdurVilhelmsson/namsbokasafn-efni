  "questions": [
    {
      "id": 348959,
      "is_answer_order_important": false,
      "stimulus_html": "",
      "stem_html": "Show the mechanism for formation of a Boc derivative by reaction of an amino acid with di-<i>tert</i>-butyl dicarbonate.",
      "answers": [],
      "hints": [],
      "formats": [
        "free-response"
      ],
      "combo_choices": [],
      "collaborator_solutions": [
        {
          "images": [],
          "solution_type": "detailed",
          "content_html": "This is a typical nucleophilic acyl substitution reaction, with the amine of the amino acid as the nucleophile and <i>tert</i>-butyl carbonate as the leaving group. The <i>tert</i>-butyl carbonate then loses CO<sub>2</sub> and gives <i>tert</i>-butoxide, which is protonated."
        }
      ],
      "community_solutions": []
    }
