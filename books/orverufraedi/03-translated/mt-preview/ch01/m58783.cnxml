<entry align="left">desímetri (dm)</entry>
<entry align="left">1/10</entry>
<entry align="left">1 dm = 0,1 m = 10<sup>−1</sup> m</entry>
</row>
<row valign="top">
<entry align="left">sentímetri (cm)</entry>
<entry align="left">1/100</entry>
<entry align="left">1 cm = 0,01 m = 10<sup>−2</sup> m</entry>
</row>
<row valign="top">
<entry align="left">millímetri (mm)</entry>
<entry align="left">1/1000</entry>
<entry align="left">1 mm = 0,001 m = 10<sup>−3</sup> m</entry>
</row>
