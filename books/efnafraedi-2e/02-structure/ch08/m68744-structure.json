      "media": {
        "id": "fs-idp213482864",
        "alt": "Two peanut-shaped orbitals are shown, lying vertically and parallel with one another. They overlap one another along the top and bottom of the orbital.",
        "src": "../../media/CNX_Chem_08_01_pi.jpg",
