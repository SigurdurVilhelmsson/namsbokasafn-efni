      "id": "CNX_Chem_08_01_sigma",
      "class": "scaled-down",
      "caption": {
        "segmentId": "m68744:caption:CNX_Chem_08_01_sigma-caption"
      },
      "media": {
        "id": "fs-idp92578528",
        "alt": "Three diagrams are shown and labeled “a,” “b,” and “c.” Diagram a shows two spherical orbitals lying side by side and overlapping. Diagram b shows one spherical and one peanut-shaped orbital lying near one another so that the spherical orbital overlaps with one end of the peanut-shaped orbital. Diagram c shows two peanut-shaped orbitals lying end to end so that one end of each orbital overlaps the other.",
        "src": "../../media/CNX_Chem_08_01_sigma.jpg",
        "mimeType": "image/jpeg"
      }
    },
