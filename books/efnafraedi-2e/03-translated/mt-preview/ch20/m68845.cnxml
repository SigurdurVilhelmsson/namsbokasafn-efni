  <md:title>Inngangur</md:title>
  <md:abstract><list id="list-00001"><item>Kolvetni</item><item>Alkóhól og etrar</item><item>Aldehýð, ketón, karboxýlsýrur og estrar</item><item>Amín og amíð</item></list></md:abstract>
  <md:uuid>a846bf55-732b-4e0b-b959-570ea8cf13e4</md:uuid>
