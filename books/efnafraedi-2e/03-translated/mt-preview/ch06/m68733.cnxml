</row>
<row valign="top">
<entry align="left">4</entry>
<entry align="left">0</entry>
<entry align="left">0</entry>
<entry align="left"><m:math><m:mrow><m:mo>−</m:mo><m:mspace width="0.2em"/><m:mfrac><m:mn>1</m:mn><m:mn>2</m:mn></m:mfrac></m:mrow></m:math></entry>
</row>
<row valign="top">
<entry align="left">4</entry>
<entry align="left">1</entry>
<entry align="left">−1</entry>
<entry align="left"><m:math><m:mrow><m:mo>+</m:mo><m:mspace width="0.2em"/><m:mfrac><m:mn>1</m:mn><m:mn>2</m:mn></m:mfrac></m:mrow></m:math></entry>
</row>
<row valign="top">
<entry align="left">4</entry>
<entry align="left">1</entry>
<entry align="left">0</entry>
