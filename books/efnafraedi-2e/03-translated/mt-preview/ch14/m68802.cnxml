  <md:title>Inngangur</md:title>
  <md:abstract><list id="list-00001"><item>Brønsted-Lowry sýrur og basar</item><item>pH og pOH</item><item>Hlutfallslegur styrkur sýra og basa</item><item>Vatnsrof saltlausna</item><item>Fjölvirkar sýrur</item><item>Stuðpúðar</item><item>Sýru-basa títranir</item></list></md:abstract>
