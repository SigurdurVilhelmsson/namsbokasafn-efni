<thead>
<row valign="top">
<entry align="center">Efnasamband</entry>
<entry align="center"><m:math><m:mrow><m:mtext>Δ</m:mtext><m:msubsup><m:mi>G</m:mi><m:mtext>f</m:mtext><m:mo>°</m:mo></m:msubsup><m:mspace width="0.2em"/><m:mtext>(kJ/mol)</m:mtext></m:mrow></m:math></entry>
<entry align="center"><m:math><m:mrow><m:mtext>Δ</m:mtext><m:msubsup><m:mi>H</m:mi><m:mtext>f</m:mtext><m:mo>°</m:mo></m:msubsup><m:mspace width="0.2em"/><m:mtext>(kJ/mol)</m:mtext></m:mrow></m:math></entry>
<entry align="center"><m:math><m:mrow><m:mi>S</m:mi><m:mtext>°</m:mtext><m:mspace width="0.2em"/><m:mtext>(J/K·mol)</m:mtext></m:mrow></m:math></entry>
