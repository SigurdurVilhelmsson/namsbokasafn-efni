  <md:title>Inngangur</md:title>
  <md:abstract><list id="list-00001"><item>Jöfnun oxunar-afoxunarhvarfa</item><item>Galvanísk rafefnafræðileg hólf</item><item>Staðalafoxunarspenna</item><item>Nernst-jafnan</item><item>Rafhlöður og efnarafalar</item><item>Tæring</item><item>Rafgreining</item></list></md:abstract>
  <md:uuid>7c92f9c8-534d-4d39-ac6c-cbb9798c92da</md:uuid>
