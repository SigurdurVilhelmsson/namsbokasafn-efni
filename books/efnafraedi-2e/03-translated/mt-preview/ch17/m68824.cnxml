</row>
<row><entry><m:math><m:mrow><m:msubsup><m:mi>E</m:mi><m:mrow><m:mtext>cell</m:mtext></m:mrow><m:mo>°</m:mo></m:msubsup><m:mo>=</m:mo><m:mspace width="0.2em"/><m:mfrac><m:mrow><m:mn>0.02</m:mn><m:mtext>57 V</m:mtext></m:mrow><m:mi>n</m:mi></m:mfrac><m:mspace width="0.2em"/><m:mtext>ln</m:mtext><m:mspace width="0.2em"/><m:mi>K</m:mi><m:mo>=</m:mo><m:mspace width="0.2em"/><m:mfrac><m:mrow><m:mn>0.0</m:mn><m:mtext>592 V</m:mtext></m:mrow><m:mi>n</m:mi></m:mfrac><m:mspace width="0.2em"/><m:mtext>log</m:mtext><m:mspace width="0.2em"/><m:mi>K</m:mi><m:mspace width="5em"/><m:mo stretchy="false">(</m:mo><m:mtext>at 298.15</m:mtext><m:mspace width="0.2em"/><m:mi>K</m:mi><m:mo stretchy="false">)</m:mo></m:mrow></m:math></entry>
