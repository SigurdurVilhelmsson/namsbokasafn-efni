<row>
<entry namest="c1" nameend="c5" align="center">Spáð og mæld gildi van't Hoff-stuðuls fyrir nokkrar 0,050 <emphasis effect="italics">m</emphasis> vatnslausnir</entry>
</row>
<row valign="top">
<entry valign="top" align="center">Formúlueining</entry>
<entry valign="top" align="center">Flokkun</entry>
<entry valign="top" align="center">Upplausnarafurðir</entry>
<entry valign="top" align="center"><emphasis effect="italics">i</emphasis> (spáð)</entry>
<entry valign="top" align="center"><emphasis effect="italics">i</emphasis> (mælt)</entry>
</row>
</thead>
<tbody>
<row valign="top">
<entry valign="top" align="center">C<sub>12</sub>H<sub>22</sub>O<sub>11</sub> (súkrósi)</entry>
<entry valign="top" align="center">Órafkleyft efni</entry>
<entry valign="top" align="center">C<sub>12</sub>H<sub>22</sub>O<sub>11</sub></entry>
<entry valign="top" align="center">1</entry>
<entry valign="top" align="center">1,0</entry>
</row>
<row valign="top">
<entry valign="top" align="center">NaCl</entry>
<entry valign="top" align="center">Sterkur rafkleyfi</entry>
<entry valign="top" align="center">Na<sup>+</sup>, Cl<sup>−</sup></entry>
<entry valign="top" align="center">2</entry>
<entry valign="top" align="center">1,9</entry>
</row>
<row valign="top">
<entry valign="top" align="center">HCl</entry>
<entry valign="top" align="center">Sterkur rafkleyfi (sýra)</entry>
<entry valign="top" align="center">H<sub>3</sub>O<sup>+</sup>, Cl<sup>−</sup></entry>
<entry valign="top" align="center">2</entry>
<entry valign="top" align="center">1,9</entry>
</row>
<row valign="top">
<entry valign="top" align="center">MgSO<sub>4</sub></entry>
<entry valign="top" align="center">Sterkur rafkleyfi</entry>
<entry valign="top" align="center">Mg<sup>2+</sup>, SO<sub>4</sub><sup>2−</sup>,</entry>
<entry valign="top" align="center">2</entry>
<entry valign="top" align="center">1,3</entry>
</row>
<row valign="top">
<entry valign="top" align="center">MgCl<sub>2</sub></entry>
<entry valign="top" align="center">Sterkur rafkleyfi</entry>
<entry valign="top" align="center">Mg<sup>2+</sup>, 2Cl<sup>−</sup></entry>
<entry valign="top" align="center">3</entry>
<entry valign="top" align="center">2,7</entry>
</row>
<row valign="top">
<entry valign="top" align="center">FeCl<sub>3</sub></entry>
<entry valign="top" align="center">Sterkur rafkleyfi</entry>
<entry valign="top" align="center">Fe<sup>3+</sup>, 3Cl<sup>−</sup></entry>
