  <md:title>Inngangur</md:title>
  <md:abstract><list id="list-00001"><item>Kjarnabygging og stöðugleiki</item><item>Kjarnajöfnur</item><item>Geislavirkt niðurbrot</item><item>Umbreyting og kjarnorka</item><item>Notkun geislasamsæta</item><item>Líffræðileg áhrif geislunar</item></list></md:abstract>
