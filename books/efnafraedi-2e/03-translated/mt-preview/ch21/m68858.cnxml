<colspec colnum="3" colname="c3"/>
<colspec colnum="4" colname="c4"/>
<thead valign="middle">
<row valign="middle">
<entry namest="c1" nameend="c4" align="center">Einingar notaðar til að mæla geislun</entry>
</row>
