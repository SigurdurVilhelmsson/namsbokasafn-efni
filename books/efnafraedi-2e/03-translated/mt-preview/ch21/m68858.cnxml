<entry align="left">2–3 vikur</entry>
</row>
<row valign="middle">
<entry align="left">90</entry>
<entry align="left">niðurgangur</entry>
<entry align="left">—</entry>
</row>
<row valign="middle">
<entry align="left">100</entry>
<entry align="left">blæðing</entry>
<entry align="left">—</entry>
</row>
<row valign="middle">
<entry align="left">400</entry>
<entry align="left">mögulegur dauði</entry>
<entry align="left">innan 2 mánaða</entry>
</row>
