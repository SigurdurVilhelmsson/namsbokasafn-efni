  <md:title>Inngangur</md:title>
  <md:abstract><list id="list-00001"><item>Útfelling og upplausn</item><item>Lewis-sýrur og -basar</item><item>Margföld jafnvægi</item></list></md:abstract>
  <md:uuid>8d42ec0e-c529-4663-ac18-2f41a286c668</md:uuid>
