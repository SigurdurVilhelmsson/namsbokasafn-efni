      "title": {
        "segmentId": "m66443:title:fs-id1511912-title",
        "text": "DNA Double-Helix Structure"
      },
      "content": [
        {
          "type": "para",
          "id": "fs-id2188236",
          "segmentId": "m66443:para:fs-id2188236"
        },
        {
          "type": "figure",
          "id": "fig-ch03_05_02",
          "caption": {
            "segmentId": "m66443:caption:fig-ch03_05_02-caption"
          },
          "media": {
            "id": "fs-id1368373",
            "alt": "The molecular structure of D N A is shown. D N A consists of two antiparallel strands twisted in a double helix. The phosphate backbone is on the outside, and the nitrogenous bases face one another on the inside.  The bases appear as strands between the phosphate backbone of the double helix.",
            "src": "../../media/Figure_03_05_02-fbf5.jpg",
            "mimeType": "image/jpg"
          }
        },
        {
          "type": "para",
