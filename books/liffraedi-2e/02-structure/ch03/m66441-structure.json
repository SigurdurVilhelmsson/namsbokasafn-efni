              "media": {
                "id": "fs-id2927265",
                "alt": "The molecular structures of alpha-linolenic acid, an omega-3 fatty acid is shown. Alpha-linolenic acid has three double bonds located eight, eleven, and fourteen residues from the acetyl group. It has a hooked shape.",
                "src": "../../media/Figure_03_03_07-cb9e.jpg",
                "mimeType": "image/jpg"
              }
            },
