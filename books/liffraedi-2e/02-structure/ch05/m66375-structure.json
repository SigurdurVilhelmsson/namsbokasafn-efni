        {
          "type": "figure",
          "id": "fig-ch05_03_01",
          "caption": {
            "segmentId": "m66375:caption:fig-ch05_03_01-caption"
          },
          "media": {
            "id": "fs-id2187880",
            "alt": "This illustration shows a membrane bilayer with a potassium channel embedded in it. The cytoplasm has a high concentration of potassium associated with a negatively charged molecule. The extracellular fluid has a high concentration of sodium associated with chlorine ions.",
            "src": "../../media/Figure_05_03_01-d7da.jpg",
            "mimeType": "image/jpg"
          }
        },
        {
          "type": "figure",
          "id": "fs-idm491659440",
          "caption": {
            "segmentId": "m66375:caption:fs-idm491659440-caption"
          },
          "media": {
            "id": "fs-idm702493232",
            "alt": "This illustration shows a membrane bilayer with a potassium channel called a proton pump embedded in it. Hydrogen ions flow out of the cell through a proton pump, then back into the cell as part of the sucrose-proton cotransporter. Sucrose flows with the protons from the lower concentration outside the cell to the higher concentration inside the cell, which is against the concentration gradient.",
            "src": "../../media/gradient.png",
            "mimeType": "image/png"
          }
        }
      ]
    },
